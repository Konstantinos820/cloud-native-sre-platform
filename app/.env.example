# Application Settings
APP_NAME=sre-platform-api
APP_VERSION=0.1.0

# Database Configuration (Defaults for local PostgreSQL container)
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app_db

# Database Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=5